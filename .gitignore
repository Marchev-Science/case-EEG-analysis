# Data — never commit raw recordings
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
*.xdf
*.fif
*.edf
*.set
*.fdt

# Python
.venv/
venv/
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.ipynb_checkpoints/
.mypy_cache/
.ruff_cache/

# Notebooks — strip outputs before committing if you can
